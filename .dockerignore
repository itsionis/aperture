# Reinstalled fresh in the image; never ship the host tree.
node_modules
.pnpm-store

# Build output — regenerated by `pnpm build` in the image.
.next
out
dist
*.tsbuildinfo

# Secrets — injected at runtime via compose env_file, never baked in.
.env
.env.*
!.env.example

# Re-fetchable SDE download cache (operator runs ingest via /setup).
.sde-cache

# VCS, CI, docs, editor — not needed to build or run.
.git
.github
.vscode
.idea
# docs/ is excluded EXCEPT the ESI swagger file, which the route resolver reads
# at runtime (src/lib/esi/routes.ts). The contents-glob form is required so the
# re-include survives the excluded parent directory.
docs/*
!docs/ESI
docs/ESI/*
!docs/ESI/swagger.json
tests
coverage

# OS cruft
.DS_Store
Thumbs.db
